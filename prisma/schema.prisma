generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id              String           @id @default(cuid())
  email           String           @unique
  name            String
  referralCode    String           @unique
  referredById    String?
  referredBy      User?            @relation("Referrals", fields: [referredById], references: [id])
  referrals       User[]           @relation("Referrals")
  referralBonuses ReferralBonus[]  @relation("BonusOwner")
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model ReferralBonus {
  id        String      @id @default(cuid())
  userId    String
  user      User        @relation("BonusOwner", fields: [userId], references: [id])
  amount    Float
  status    BonusStatus @default(PENDING)
  reason    String
  expiresAt DateTime?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

enum BonusStatus {
  PENDING
  APPROVED
  PAID
  EXPIRED
  REJECTED
}
